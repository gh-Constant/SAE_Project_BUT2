# Database Configuration
DATABASE_URL="mysql://sae_user:sae_password@127.0.0.1:3306/sae_project_db"
SHADOW_DATABASE_URL="mysql://sae_user:sae_password@127.0.0.1:3307/sae_project_shadow_db"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Email Configuration (Gmail SMTP)
# Pour Gmail, vous devez créer un "App Password" (Mot de passe d'application)
# Étapes: https://support.google.com/accounts/answer/185833
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="votre.email@gmail.com"
SMTP_PASS="votre-mot-de-passe-application-16-caracteres"
SMTP_FROM="votre.email@gmail.com"

# Frontend URL (pour les liens dans les emails)
FRONTEND_URL="http://localhost:5173"

# Environment
NODE_ENV="development"
