# Database Configuration
DATABASE_URL="mysql://sae_user:sae_password@127.0.0.1:3306/sae_project_db"
SHADOW_DATABASE_URL="mysql://sae_user:sae_password@127.0.0.1:3307/sae_project_shadow_db"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Email Configuration (Gmail SMTP)
# Pour Gmail, vous devez créer un "App Password" (Mot de passe d'application)
# Étapes: https://support.google.com/accounts/answer/185833
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="votre.email@gmail.com"
SMTP_PASS="votre-mot-de-passe-application-16-caracteres"
SMTP_FROM="votre.email@gmail.com"

# Frontend URL (pour les liens dans les emails)
FRONTEND_URL="http://localhost:4200"
BACKEND_PUBLIC_URL="http://localhost:3000"

# OAuth Session Configuration
OAUTH_SESSION_SECRET="your-super-secret-oauth-session-key-change-this-in-production"

# Google OAuth Configuration
# Créez un client OAuth "Web application" dans Google Cloud Console
# Console : https://console.cloud.google.com/apis/credentials
# Écran de consentement : https://console.cloud.google.com/apis/credentials/consent
# Redirect URI locale attendue par le backend :
# http://localhost:3000/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:3000/api/v1/auth/google/callback"

# Discord OAuth Configuration
# Créez une application dans le Discord Developer Portal
# Portal : https://discord.com/developers/applications
# Redirect URI locale attendue par le backend :
# http://localhost:3000/api/v1/auth/discord/callback
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_CALLBACK_URL="http://localhost:3000/api/v1/auth/discord/callback"

# Environment
NODE_ENV="development"
